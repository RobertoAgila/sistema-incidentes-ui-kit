{
  "info": {
    "_postman_id": "886e034a-43c1-4f7a-a123-actividad8tickets",
    "name": "Actividad 8 - API Tickets",
    "description": "Colección de pruebas CRUD para la API REST del Sistema de Gestión de Incidentes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "ticketId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "1. Estado de la API",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "2. Crear ticket - POST",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "if (body.data && body.data._id) {",
              "  pm.collectionVariables.set('ticketId', body.data._id);",
              "}",
              "pm.test('Estado 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"titulo\": \"Falla de conexión WiFi\",\n  \"descripcion\": \"El computador no logra conectarse a la red inalámbrica institucional.\",\n  \"categoria\": \"Red\",\n  \"prioridad\": \"Alta\",\n  \"estado\": \"Abierto\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tickets",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tickets"]
        }
      }
    },
    {
      "name": "3. Listar tickets - GET",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tickets",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tickets"]
        }
      }
    },
    {
      "name": "4. Buscar ticket por ID - GET",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tickets", "{{ticketId}}"]
        }
      }
    },
    {
      "name": "5. Actualizar ticket - PUT",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"estado\": \"En Progreso\",\n  \"prioridad\": \"Media\",\n  \"descripcion\": \"El técnico inició la revisión de la configuración inalámbrica.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tickets", "{{ticketId}}"]
        }
      }
    },
    {
      "name": "6. Eliminar ticket - DELETE",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "tickets", "{{ticketId}}"]
        }
      }
    }
  ]
}
